{
  "info": {
    "name": "Healthcare Platform - Doctor Service",
    "description": "Complete test collection for Doctor Profile & Admin Verification",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "doctorToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "doctorId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1 - AUTH",
      "item": [
        {
          "name": "Register Doctor",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Doctor User\",\n  \"email\": \"doctor@gmail.com\",\n  \"password\": \"1234\",\n  \"role\": \"doctor\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login Doctor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('doctorToken', res.token);",
                  "  console.log('Doctor token saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"doctor@gmail.com\",\n  \"password\": \"1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@gmail.com\",\n  \"password\": \"1234\",\n  \"role\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('adminToken', res.token);",
                  "  console.log('Admin token saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@gmail.com\",\n  \"password\": \"1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "2 - DOCTOR PROFILE",
      "item": [
        {
          "name": "Create / Update Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.doctor && res.doctor._id) {",
                  "  pm.collectionVariables.set('doctorId', res.doctor._id);",
                  "  console.log('Doctor ID saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{doctorToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"specialization\": \"Cardiology\",\n  \"experience\": 5,\n  \"hospital\": \"Tangalle Hospital\",\n  \"bio\": \"Experienced cardiologist\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/doctor/profile",
              "host": ["{{baseUrl}}"],
              "path": ["doctor", "profile"]
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{doctorToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/doctor/profile",
              "host": ["{{baseUrl}}"],
              "path": ["doctor", "profile"]
            }
          }
        },
        {
          "name": "Delete Profile",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{doctorToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/doctor/profile",
              "host": ["{{baseUrl}}"],
              "path": ["doctor", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "3 - ADMIN VERIFICATION",
      "item": [
        {
          "name": "Get Unverified Doctors",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/doctor/unverified",
              "host": ["{{baseUrl}}"],
              "path": ["doctor", "unverified"]
            }
          }
        },
        {
          "name": "Verify Doctor",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/doctor/verify/{{doctorId}}",
              "host": ["{{baseUrl}}"],
              "path": ["doctor", "verify", "{{doctorId}}"]
            }
          }
        },
        {
          "name": "Get Verified Doctors",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/doctor/verified",
              "host": ["{{baseUrl}}"],
              "path": ["doctor", "verified"]
            }
          }
        }
      ]
    }
  ]
}