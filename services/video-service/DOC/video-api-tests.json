{
  "info": {
    "name": "Healthcare Platform - Video Service",
    "description": "Complete test collection for Telemedicine Video Consultation",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "userToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "roomId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1 - AUTH",
      "item": [
        {
          "name": "Login Doctor (To get Token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('userToken', res.token);",
                  "  console.log('Token saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"doctor@gmail.com\",\n  \"password\": \"1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "2 - VIDEO SERVICE",
      "item": [
        {
          "name": "Health Check (Direct Port 3006)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3006/health",
              "host": [
                "http://localhost:3006"
              ],
              "path": [
                "health"
              ]
            }
          }
        },
        {
          "name": "Generate Meeting Room",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.roomId) {",
                  "  pm.collectionVariables.set('roomId', res.roomId);",
                  "  console.log('Room ID saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"appointmentId\": \"appt_12345\",\n  \"patientId\": \"pat_67890\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/video/sessions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "video",
                "sessions"
              ]
            }
          }
        },
        {
          "name": "Get Meeting Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/video/sessions/{{roomId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "video",
                "sessions",
                "{{roomId}}"
              ]
            }
          }
        }
      ]
    }
  ]
}
